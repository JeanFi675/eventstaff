# =============================================================================
# Variables d'environnement — appel-benevoles
# =============================================================================
# Convention de périmètre :
#   [BACKEND/CLI]  → utilisée uniquement par scripts Node (CLI Supabase, scripts/).
#                    JAMAIS injectée dans le bundle Vite (pas de préfixe VITE_).
#   [FRONTEND]     → préfixe VITE_, injectée en clair dans le bundle JS public.
#                    Toute valeur ici est publique. NE JAMAIS y placer un secret.
#   [EDGE FUNCTION] → configurée via `supabase secrets set ...`, jamais lue côté
#                    front. Ne pas la définir ici en prod ; cette ligne sert
#                    uniquement à la doc et au dev local.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Backend / CLI (NON exposé au frontend)
# -----------------------------------------------------------------------------
# [BACKEND/CLI] URL projet Supabase, utilisée par les scripts Node et le CLI.
SUPABASE_URL=https://your-project.supabase.co

# [BACKEND/CLI] Clé anon. Publique par nature (utilisable côté client), mais
# on garde une copie ici pour les scripts qui ne passent pas par Vite.
SUPABASE_ANON_KEY=your_anon_key_here

# [BACKEND/CLI uniquement — JAMAIS frontend] Clé service_role. Donne tous les
# droits sur la base (bypass RLS). À utiliser exclusivement dans des scripts
# locaux ou via `supabase secrets set` pour les Edge Functions. Ne JAMAIS
# référencer cette variable dans `src/` ni la préfixer VITE_.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# Supabase — Frontend (exposé au client, injecté dans le bundle)
# -----------------------------------------------------------------------------
# [FRONTEND] URL publique du projet Supabase (équivalent SUPABASE_URL).
VITE_SUPABASE_URL=https://your-project.supabase.co

# [FRONTEND] Clé anon publique. Publique par nature (RLS protège les données).
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# -----------------------------------------------------------------------------
# URLs de l'application
# -----------------------------------------------------------------------------
# [FRONTEND] URL de dev local (utilisée pour les redirections d'auth).
VITE_APP_URL_LOCAL=http://localhost:5500

# [FRONTEND] URL de production publique (GitHub Pages, etc.).
VITE_APP_URL_PRODUCTION=https://your-username.github.io/your-repo-name

# -----------------------------------------------------------------------------
# Application — Configuration générale
# -----------------------------------------------------------------------------
# [BACKEND/CLI] Mode d'exécution.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Edge Functions — Secrets (configurés via `supabase secrets set ...`)
# -----------------------------------------------------------------------------
# Les secrets ci-dessous sont consommés UNIQUEMENT par les Edge Functions
# (`send-planning`, `create-benevole`). Ils ne doivent jamais être lus depuis
# le front ni committés. Pour les configurer en prod :
#
#   supabase secrets set SMTP_HOST=...
#   supabase secrets set SMTP_PORT=...
#   supabase secrets set SMTP_USER=...
#   supabase secrets set SMTP_PASS=...
#
# Vérification : `supabase secrets list` doit lister ces clés.
# La variable `SUPABASE_SERVICE_ROLE_KEY` est injectée automatiquement par la
# plateforme Edge Functions ; pas besoin de la déclarer manuellement.
